<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="20dp"
    android:gravity="center"
    android:orientation="vertical"
    tools:context=".AuthorFragment">

    <!-- Фотография (можно заменить на вашу) -->
    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/profile_photo"
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_marginBottom="40dp"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/author"
        app:shapeAppearanceOverlay="@style/circular"
        app:strokeColor="@color/light_orange"
        app:strokeWidth="5dp" />

    <!-- ФИО -->
    <TextView
        android:id="@+id/fullname_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Еременко Анжелика Васильевна"
        android:textSize="20sp"
        android:textAlignment="center"
        android:textColor="@color/chocolate"
        android:layout_marginBottom="5dp"/>

    <!-- Группа университета -->
    <TextView
        android:id="@+id/group_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ИКБО-03-22"
        android:textSize="20sp"
        android:textAlignment="center"
        android:layout_marginBottom="30dp"/>

    <!-- Номер телефона -->
    <TextView
        android:id="@+id/phone_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="+7 (963) 770-53-43"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="5dp"/>

    <!-- Почта -->
    <TextView
        android:id="@+id/email_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="lika.eriomenko@gmail.com"
        android:textSize="16sp"
        android:textAlignment="center"
        android:layout_marginBottom="80dp"/>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/github"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:background="@drawable/github_mark"
        android:backgroundTint="@color/black"
        android:layout_marginStart="10dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:layout_marginTop="30dp"
        android:orientation="vertical">
        <androidx.appcompat.widget.AppCompatButton
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="10dp"
            android:text="Выйти"
            android:background="@drawable/edit_text_rounded_corner"
            android:backgroundTint="@color/light_orange"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:id="@+id/logout"/>
    </LinearLayout>
</LinearLayout>